{
  "name": "psc",
  "private": true,
  "description": "Root launcher for the Gemma Theia IDE workspace",
  "scripts": {
    "setup": "node scripts/project-cli.js setup",
    "bootstrap": "node scripts/project-cli.js bootstrap",
    "start": "node scripts/project-cli.js start",
    "stop": "node scripts/project-cli.js stop",
    "logs": "node scripts/project-cli.js logs",
    "logs:llm": "node scripts/project-cli.js logs:llm",
    "canopy:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-canopy-wsl.ps1",
    "canopy:install-online": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-canopy-wsl-online.ps1",
    "canopy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canopy-dashboard.ps1",
    "canopy:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/canopy-dashboard.ps1 -PrepareWorktrees",
    "mcp:agent": "IPE\\llm-server\\.venv\\Scripts\\python.exe IPE\\mcp\\psc_agent_mcp.py",
    "window": "node scripts/project-cli.js window"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "http-proxy": "^1.18.1"
  }
}

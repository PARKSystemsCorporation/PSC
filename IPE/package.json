{
  "name": "gemma-theia-ide",
  "version": "1.0.0",
  "private": true,
  "description": "PARK Systems Coder, a local AI coding IDE built on Eclipse Theia with Lila Agent orchestration and mobile/iPad connectivity",
  "license": "MIT",
  "scripts": {
    "clean": "lerna clean && rimraf node_modules",
    "build": "lerna run build",
    "watch": "lerna run watch --parallel",
    "start:debug": "cd applications/browser && yarn start --inspect",
    "download:plugins": "theia download:plugins --rate-limit=15",
    "prepare": "lerna run prepare",
    "postinstall": "patch-package",
    "setup:native": "node scripts/setup-native.js",
    "bootstrap": "yarn install --ignore-scripts && patch-package && yarn run setup:native"
  },
  "workspaces": [
    "applications/*",
    "extensions/*"
  ],
  "devDependencies": {
    "lerna": "^8.1.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "resolutions": {
    "inversify": "6.0.1"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "vscode-builtin-extensions-pack": "https://open-vsx.org/api/eclipse-theia/builtin-extension-pack/1.90.0/file/eclipse-theia.builtin-extension-pack-1.90.0.vsix"
  }
}

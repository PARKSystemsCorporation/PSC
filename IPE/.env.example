# ==============================================================================
# Gemma Theia IDE — Environment Configuration
# ==============================================================================
# Copy this file to .env and customize values.

# ── IDE Settings ─────────────────────────────────────────────────────
IDE_PORT=3000
IDE_SSL_PORT=3443

# ── LLM Backend ─────────────────────────────────────────────────────
# Options: "llamacpp" or "vllm"
LLM_BACKEND=llamacpp

# ── llama.cpp Settings ──────────────────────────────────────────────
# Path to directory containing GGUF model files
MODELS_DIR=./models

# Model filename (must exist in MODELS_DIR)
GEMMA_MODEL=gemma-4-12b-it-Q4_K_M.gguf

# Context window size
CTX_SIZE=8192

# GPU layers to offload (-1 = all layers, 0 = CPU only)
GPU_LAYERS=-1

# Parallel inference slots
PARALLEL_SLOTS=4

# ── vLLM Settings (only if LLM_BACKEND=vllm) ────────────────────────
VLLM_MODEL=google/gemma-4-12b-it
TENSOR_PARALLEL=1
GPU_MEM_UTIL=0.9

# HuggingFace token (required for gated models)
HF_TOKEN=

PERSONAPLEX_ENABLED=false
PERSONAPLEX_PORT=8998
PERSONAPLEX_EXTRA_ARGS=

MEMPALACE_ENABLED=true
MEMPALACE_PALACE_PATH=./.mempalace/palace
MEMPALACE_WING=psc
MEMPALACE_AUTO_SEARCH=true

# ── Workspace ────────────────────────────────────────────────────────
# Host directory to mount as workspace in the IDE
# `..` mounts the full cloned repo when you use the root launcher.
HOST_WORKSPACE=..

# ── Railway Tunnel (optional) ────────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# ── LLM Server (FastAPI proxy on the host) ──────────────────────────
# Set to false to skip auto-launching the Python LLM server from `npm start`
# (e.g. if you already run it yourself in another terminal).
START_LLM_SERVER=true
LLM_SERVER_PORT=8000

# Auto-launch a Neutralino desktop window pointing at the proxy on `npm start`.
# Set to false on headless servers, or if you prefer a browser tab.
OPEN_WINDOW=true

# ── Telegram Bridge (optional) ──────────────────────────────────────
# Lets you chat with your local coding agent from your phone.
# 1. Talk to @BotFather on Telegram, /newbot, paste the token below.
# 2. Send your bot any message, then call /whoami to get your chat id, and
#    add it to TELEGRAM_ALLOWED_CHAT_IDS (comma-separated for multiple users).
# 3. Restart `npm start`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_MODE=chat

# ==============================================================================
# Gemma Theia IDE — Environment Configuration
# ==============================================================================
# Copy this file to .env and customize values.

# ── IDE Settings ─────────────────────────────────────────────────────
IDE_PORT=3000
IDE_SSL_PORT=3443

# ── LLM Backend ─────────────────────────────────────────────────────
# Options: "llamacpp" or "vllm"
LLM_BACKEND=llamacpp

# ── llama.cpp Settings ──────────────────────────────────────────────
# Path to directory containing GGUF model files
MODELS_DIR=./models

# Model filename (must exist in MODELS_DIR)
GEMMA_MODEL=gemma-4-12b-it-Q4_K_M.gguf

# Context window size
CTX_SIZE=8192

# GPU layers to offload (-1 = all layers, 0 = CPU only)
GPU_LAYERS=-1

# Parallel inference slots
PARALLEL_SLOTS=4

# ── vLLM Settings (only if LLM_BACKEND=vllm) ────────────────────────
VLLM_MODEL=google/gemma-4-12b-it
TENSOR_PARALLEL=1
GPU_MEM_UTIL=0.9

# HuggingFace token (required for gated models)
HF_TOKEN=

PERSONAPLEX_ENABLED=false
PERSONAPLEX_PORT=8998
PERSONAPLEX_EXTRA_ARGS=

MEMPALACE_ENABLED=false
MEMPALACE_PALACE_PATH=./.mempalace/palace
MEMPALACE_WING=psc
MEMPALACE_AUTO_SEARCH=true

# ── Workspace ────────────────────────────────────────────────────────
# Host directory to mount as workspace in the IDE
# `..` mounts the full cloned repo when you use the root launcher.
HOST_WORKSPACE=..

# ── Railway Tunnel (optional) ────────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

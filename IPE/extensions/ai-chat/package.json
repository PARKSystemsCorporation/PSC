{
  "name": "gemma-ai-chat",
  "version": "1.0.0",
  "description": "PARK Systems Coder chat panel with Lila Agent orchestration, streaming conversations, code generation, refactoring, and debugging",
  "keywords": ["theia-extension"],
  "license": "MIT",
  "files": ["lib", "src"],
  "main": "lib/browser/ai-chat-frontend-module",
  "dependencies": {
    "@theia/core": "1.54.0",
    "@theia/editor": "1.54.0",
    "@theia/filesystem": "1.54.0",
    "@theia/monaco": "1.54.0",
    "@theia/terminal": "1.54.0",
    "@theia/workspace": "1.54.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "typescript": "~5.4.5",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "clean": "rimraf lib",
    "build": "tsc",
    "watch": "tsc -w",
    "prepare": "yarn build"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/ai-chat-frontend-module"
    }
  ]
}

{
  "name": "gemma-theia-browser",
  "version": "1.0.0",
  "private": true,
  "description": "Gemma Theia IDE - Browser Application",
  "dependencies": {
    "@theia/core": "1.54.0",
    "@theia/editor": "1.54.0",
    "@theia/file-search": "1.54.0",
    "@theia/filesystem": "1.54.0",
    "@theia/getting-started": "1.54.0",
    "@theia/markers": "1.54.0",
    "@theia/messages": "1.54.0",
    "@theia/mini-browser": "1.54.0",
    "@theia/monaco": "1.54.0",
    "@theia/navigator": "1.54.0",
    "@theia/outline-view": "1.54.0",
    "@theia/output": "1.54.0",
    "@theia/plugin-ext": "1.54.0",
    "@theia/plugin-ext-vscode": "1.54.0",
    "@theia/preferences": "1.54.0",
    "@theia/process": "1.54.0",
    "@theia/scm": "1.54.0",
    "@theia/search-in-workspace": "1.54.0",
    "@theia/terminal": "1.54.0",
    "@theia/workspace": "1.54.0",
    "gemma-ai-chat": "1.0.0",
    "gemma-ai-completion": "1.0.0",
    "gemma-ai-terminal": "1.0.0",
    "gemma-connection-manager": "1.0.0",
    "gemma-mobile-ui": "1.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.54.0"
  },
  "scripts": {
    "clean": "theia clean",
    "generate": "theia generate",
    "build": "yarn generate && theia build --mode=production",
    "build:dev": "yarn generate && theia build --mode=development",
    "start": "theia start --hostname=0.0.0.0 --port=3000 --plugins=local-dir:../../plugins",
    "start:debug": "theia start --hostname=0.0.0.0 --port=3000 --plugins=local-dir:../../plugins --inspect=0.0.0.0:9229",
    "watch": "theia build --watch --mode=development"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Gemma AI IDE",
        "defaultTheme": "dark",
        "preferences": {
          "editor.fontSize": 14,
          "terminal.integrated.fontSize": 13,
          "workbench.colorTheme": "dark"
        }
      }
    },
    "backend": {
      "config": {
        "startupTimeout": -1,
        "resolveSystemPlugins": false
      }
    }
  }
}
